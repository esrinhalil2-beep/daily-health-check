<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="UTF-8">
  <title>Daily Health Check</title>

<link rel="stylesheet" href="./assets/css/main.css">
</head>
<body>

  <div class="game-area">

    <h1>Hoe was het vandaag?</h1>

    <input type="text" id="nameInput" placeholder="Typ je naam">
    <p id="greeting"></p>


    <h2>Gevoel</h2>
    <button class="gevoel">Blij</button>
    <button class="gevoel">Neutraal</button>
    <button class="gevoel">Verdrietig</button>
    <p id="gevoelText"></p>


    <h2>Voeding</h2>
    <button class="eten">Gezond gegeten</button>
    <button class="eten">Tussenin</button>
    <button class="eten">Ongezond gegeten</button>
    <p id="etenText"></p>


    <h2>Energie</h2>
    <button class="energie">Veel energie</button>
    <button class="energie">Wel oke</button>
    <button class="energie">Moe</button>
    <p id="energieText"></p>


    <h2>Stress</h2>
    <button class="stress">Geen zorgen</button>
    <button class="stress">Beetje gestresseerd</button>
    <button class="stress">Veel te gestresseerd</button>
    <p id="stressText"></p>

    <h2>Water</h2>
    <button id="waterBtn">Drink water</button>
    <button id="resetBtn">Reset</button>
    <p id="waterText">0 glazen</p>


    <h2>Rust moment</h2>
    <button id="timerBtn">Start</button>
    <p id="timerText"></p>

    <button id="checkBtn">Check mijn dag</button>
    <p id="finalText"></p>


    <button id="darkBtn">Dark mode</button>

  </div>

  <script src="assets/js/main.js"></script>
</body>
</html>
